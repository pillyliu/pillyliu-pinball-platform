{
  "name": "pillyliu-pinball-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "pillyliu-landing",
    "lpl-library",
    "lpl-standings",
    "lpl-stats",
    "lpl-targets"
  ],
  "scripts": {
    "dev:pinprof-admin": "npm --prefix \"../PinProf Admin/apps/admin-ui\" run dev",
    "build:pinprof-admin": "npm --prefix \"../PinProf Admin/apps/admin-ui\" run build",
    "start:pinprof-admin": "npm --prefix \"../PinProf Admin/apps/admin-ui\" run start",
    "check:smoke": "node tools/smoke-check.mjs",
    "build:lpl-library": "npm run build --workspace lpl-library",
    "build:lpl-standings": "npm run build --workspace lpl-standings",
    "build:lpl-stats": "npm run build --workspace lpl-stats",
    "build:lpl-targets": "npm run build --workspace lpl-targets",
    "build:pillyliu-landing": "npm run build --workspace pillyliu-landing",
    "build:all": "npm run build:pillyliu-landing && npm run build:lpl-library && npm run build:lpl-standings && npm run build:lpl-stats && npm run build:lpl-targets"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "better-sqlite3": "^12.6.2",
    "react": "^19.2.4"
  }
}
